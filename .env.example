## Required: set these before running `./deploy.sh setup`

# Primary HTTPS hostname for the app.
APP_DOMAIN=clawmail.org

# Runtime environment: use `development` for local/dev, `production` for deployed servers.
NODE_ENV=production

# Optional but recommended shared token required by POST /api/v1/domains/register.
DOMAIN_REGISTER_TOKEN=


## Auto-populated by `./deploy.sh setup`: leave blank on first setup

# 64 hex chars (32 bytes) used to encrypt DKIM private keys at rest.
DKIM_ENCRYPTION_KEY=

# Set to `false` to use an externally managed PostgreSQL instance instead.
USE_LOCAL_POSTGRES=true

# PostgreSQL connection string for the app database.
# Leave blank when USE_LOCAL_POSTGRES=true; deploy.sh will generate it on first deploy and reuse it later.
DATABASE_URL=

# SMTP TLS private key copied from the Caddy-managed certificate.
SMTP_TLS_KEY_PATH=

# SMTP TLS certificate copied from the Caddy-managed certificate.
SMTP_TLS_CERT_PATH=

# Public IPv4 address of this server. `./deploy.sh setup` will auto-detect this when blank.
# Set it manually if the detected IP is wrong or auto-detection is unavailable.
SERVER_IP=


## Optional: good defaults are provided

# Internal HTTP listener for the Node app. Caddy should proxy to this port.
PORT=3000

# Required when running behind Caddy so Express sees the real client IP.
TRUST_PROXY=1

# Set to `email` to rate-limit inbox-authenticated email routes by inbox address instead of client IP.
INBOX_RATE_LIMIT_SCOPE=ip

# Inbound SMTP listener. Use 25 in production if the host allows it.
SMTP_PORT=2525

# Optional secondary web hostname.
# Leave blank to derive `www.<APP_DOMAIN>`.
APP_WWW_DOMAIN=

# Public mail hostname used in SMTP greetings and TLS certificates.
# Leave blank to derive `mx.<APP_DOMAIN>`.
SMTP_BANNER_HOSTNAME=

# Email address Caddy uses for ACME/Let's Encrypt registration.
# Leave blank to derive `admin@<APP_DOMAIN>`.
CADDY_ADMIN_EMAIL=

# Set to `false` if you do not want the deploy script to manage Caddy.
CONFIGURE_CADDY=true

# Override if your Caddy data directory lives somewhere else.
CADDY_DATA_DIR=/var/lib/caddy/.local/share/caddy

# Application log verbosity.
LOG_LEVEL=info

# Directory for stored email attachments.
ATTACHMENTS_DIR=./attachments

# Optional attachment retention in hours. When unset, attachments do not auto-expire.
ATTACHMENT_TTL_HOURS=72
